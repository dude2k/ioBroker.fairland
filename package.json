{
  "name": "iobroker.fairland",
  "version": "0.1.5",
  "description": "ioBroker adapter for Fairland iGarden pool heat pumps and pool pumps",
  "keywords": [
    "ioBroker",
    "fairland",
    "igarden",
    "pool",
    "heat-pump",
    "pump",
    "madimack"
  ],
  "author": "dude2k",
  "license": "MIT",
  "homepage": "https://github.com/dude2k/ioBroker.fairland",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dude2k/ioBroker.fairland.git"
  },
  "bugs": {
    "url": "https://github.com/dude2k/ioBroker.fairland/issues"
  },
  "main": "build/main.js",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "admin",
    "build",
    "io-package.json",
    "LICENSE",
    "README.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:adapter": "build-adapter typescript",
    "lint": "eslint . && npm run lint:ts",
    "lint:ts": "tsc --noEmit -p tsconfig.json",
    "release": "release-script",
    "translate": "translate-adapter",
    "watch": "tsc -w -p tsconfig.json",
    "test": "npm run build",
    "test:package": "npm run build",
    "test:integration": "npm run build",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}
